<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenPhotoSort.MainPage">

    <Grid Padding="10"
          ColumnDefinitions="*"
          RowDefinitions="*,9*"
          RowSpacing="5">
        <Button
            x:Name="FilePickerBtn"
            Text="Select Folder"
            Clicked="OnFilePickerClicked"
            HorizontalOptions="Fill"
            IsEnabled="{Binding BtnIsEnabled}"/>
        <ScrollView 
            Grid.Row="1"
            HorizontalOptions="Fill"
            MaximumHeightRequest="350">
            <Editor
                x:Name="FileProps"
                Placeholder="File properties are shown here..."
                AutoSize="TextChanges"
                IsEnabled="False" />
        </ScrollView>
    </Grid>

</ContentPage>
